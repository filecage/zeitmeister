{
    "compilerOptions": {
        "target": "es2024",
        "module": "nodenext",
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "noEmit": true,
    },
    "include": [
        "src/**/*.ts"
    ]
}